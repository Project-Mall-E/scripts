# Copy to .env and fill in real values. Used when running with --store-in-database.
# See README "Storage backends" for details.

# Storage backend: leave unset or set to anything other than "supabase" for Firestore.
# Set to "supabase" to use Supabase (then set SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY below).
# STORAGE_BACKEND=supabase

# Supabase (only needed when STORAGE_BACKEND=supabase)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
