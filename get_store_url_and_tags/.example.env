# Copy to .env and fill in real values. Used when running with --store-in-database.
# See README "Storage backends" for details.

# Storage backend: defaults to Supabase.
# Set `STORAGE_BACKEND=firestore` to use Firestore instead.
# STORAGE_BACKEND=firestore

# Supabase (default): only needed when using `--store-in-database`
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
